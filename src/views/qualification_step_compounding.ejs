    table?.addEventListener('input', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLInputElement)) return;
      const row = target.closest('tr[data-run-row]');
      const runId = row?.getAttribute('data-run-id');
      const fieldId = target.getAttribute('data-field-id');
      const fieldType = target.getAttribute('data-field-type');
      if (!runId || !fieldId || !fieldType) return;
      const key = `${runId}:${fieldId}`;
      // Repaint immediate data/plots.
      safeRecomputeCharts();
      queueSave(key, async () => {
        let value = target.value;
        if (fieldType === 'tag') {
          value = target.value
            .split(',')
            .map((item) => item.trim())
            .filter(Boolean);
        }
        const form = new FormData();
        form.append('field_id', fieldId);
        form.append('value', fieldType === 'tag' ? JSON.stringify(value) : String(value));
        await post(`/qual-runs/${runId}/value`, form);
      });
    });

    table?.addEventListener('change', async (event) => {
      const target = event.target;
      if (!(target instanceof HTMLInputElement)) return;
      const row = target.closest('tr[data-run-row]');
      const runId = row?.getAttribute('data-run-id');
      if (!runId) return;

      if (target.hasAttribute('data-field-id') && target.getAttribute('data-field-type') === 'boolean') {
        const form = new FormData();
        form.append('field_id', target.getAttribute('data-field-id') || '');
        form.append('value', target.checked ? '1' : '0');
        try { await post(`/qual-runs/${runId}/value`, form); } catch {}
        safeRecomputeCharts();
        return;
      }

      const flag = target.getAttribute('data-flag');
      if (flag === 'done' || flag === 'exclude') {
        const done = row.querySelector('input[data-flag="done"]')?.checked ? '1' : '';
        const exclude = row.querySelector('input[data-flag="exclude"]')?.checked ? '1' : '';
        const form = new FormData();
        form.append('done', done);
        form.append('exclude', exclude);
        try { await post(`/qual-runs/${runId}/flags`, form); } catch {}
        safeRecomputeCharts();
        return;
      }

      if (target.hasAttribute('data-run-due')) {
        const form = new FormData();
        form.append('due_at', target.value || '');
        try { await post(`/qual-runs/${runId}/due-at`, form); } catch {}
      }
      // Recompute recommendations on committed values (after input is finalized).
      safeRecomputeCharts();
    });

    table?.addEventListener('click', async (event) => {
      const button = event.target.closest('[data-run-delete]');
      if (!button) return;
      const row = button.closest('tr[data-run-row]');
      const runId = row?.getAttribute('data-run-id');
      if (!runId) return;
      if (!confirm('Delete this run?')) return;
      try {
        await post(`/experiments/${experimentId}/qualification/${stepNumber}/runs/${runId}/delete`, new FormData());
        location.reload();
      } catch {}
    });

    document.getElementById('addRunBtn')?.addEventListener('click', async () => {
      try {
        await post(`/experiments/${experimentId}/qualification/${stepNumber}/runs`, new FormData());
        location.reload();
      } catch {}
    });

    const fieldDialog = document.getElementById('qualFieldDialog');
    document.getElementById('openQualFields')?.addEventListener('click', () => fieldDialog?.showModal());
    document.getElementById('openQualSettingsDialog')?.addEventListener('click', () => qualSettingsDialog?.showModal());
    document.getElementById('openStep3Setup')?.addEventListener('click', () => step3SetupDialog?.showModal());
    fieldDialog?.querySelectorAll('[data-close]').forEach((button) => {
      button.addEventListener('click', () => fieldDialog.close());
    });
    qualSettingsDialog?.querySelectorAll('[data-close]').forEach((button) => {
      button.addEventListener('click', () => qualSettingsDialog.close());
    });
    step3SetupDialog?.querySelectorAll('[data-close]').forEach((button) => {
      button.addEventListener('click', () => step3SetupDialog.close());
    });
    if (window.IMPlanner?.setupAutosaveForm && qualSettingsForm) {
      window.IMPlanner.setupAutosaveForm(qualSettingsForm, {
        debounceMs: 250,
        onSuccess: async (resp) => {
          let payload = null;
          try { payload = await resp.json(); } catch {}
          const assigneeId = String(payload?.assignee_user_id ?? qualStepAssigneeInput?.value ?? '');
          if (!qualStepResponsibleLabel) return;
          if (!assigneeId) {
            qualStepResponsibleLabel.textContent = '-';
            return;
          }
          const link = document.createElement('a');
          link.href = `/users/${assigneeId}`;
          link.textContent = payload?.assignee_label || qualAssignableUserById.get(assigneeId) || `User #${assigneeId}`;
          qualStepResponsibleLabel.innerHTML = '';
          qualStepResponsibleLabel.appendChild(link);
        }
      });
    }
    if (window.IMPlanner?.setupAutosaveForm && step3SetupForm) {
      window.IMPlanner.setupAutosaveForm(step3SetupForm, {
        debounceMs: 250,
        onSuccess: () => {
          syncStep3Settings();
        }
      });
    }
    document.getElementById('targetScrewRpmInput')?.addEventListener('input', syncStep3Settings);
    safeRecomputeCharts();
    syncStep3Settings();
    window.addEventListener('resize', () => {
      const container = document.getElementById('compoundingStep1Chart');
      if (container && window.echarts) {
        const chart = echarts.getInstanceByDom(container);
        chart?.resize();
      }
      const container2 = document.getElementById('compoundingStep2Chart');
      if (container2 && window.echarts) {
        const chart2 = echarts.getInstanceByDom(container2);
        chart2?.resize();
      }
      const container3 = document.getElementById('compoundingStep3Chart');
      if (container3 && window.echarts) {
        const chart3 = echarts.getInstanceByDom(container3);
        chart3?.resize();
      }
    });

    fieldDialog?.addEventListener('change', async (event) => {
      const target = event.target;
      const row = target?.closest?.('tr[data-field-row]');
      if (!row) return;
      const fieldId = row.getAttribute('data-field-id');
      if (!fieldId) return;
      const form = new FormData();
      form.append('code', row.querySelector('[data-field-code]')?.value || '');
      form.append('label', row.querySelector('[data-field-label]')?.value || '');
      form.append('field_type', row.querySelector('[data-field-type]')?.value || 'number');
      form.append('unit', row.querySelector('[data-field-unit]')?.value || '');
      form.append('required', row.querySelector('[data-field-required]')?.checked ? '1' : '');
      form.append('is_enabled', row.querySelector('[data-field-enabled]')?.checked ? '1' : '');
      try { await post(`/experiments/${experimentId}/qualification/fields/${fieldId}`, form); } catch {}
    });

    fieldDialog?.addEventListener('click', async (event) => {
      const button = event.target.closest('[data-field-delete]');
      if (!button) return;
      const row = button.closest('tr[data-field-row]');
      const fieldId = row?.getAttribute('data-field-id');
      if (!fieldId) return;
      if (!confirm('Delete this field?')) return;
      try {
        await post(`/experiments/${experimentId}/qualification/fields/${fieldId}/delete`, new FormData());
        location.reload();
      } catch {}
    });

    document.getElementById('qualImportField')?.addEventListener('click', async () => {
      const select = document.getElementById('qualLibrarySelect');
      const paramId = select?.value;
      if (!paramId) return;
      const form = new FormData();
      form.append('param_id', paramId);
      try {
        await post(`/experiments/${experimentId}/qualification/${stepNumber}/fields/import`, form);
        location.reload();
      } catch {}
    });

    document.getElementById('qualCustomFieldForm')?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const formEl = event.target;
      const body = new FormData(formEl);
      try {
        await post(`/experiments/${experimentId}/qualification/${stepNumber}/fields`, body);
        location.reload();
      } catch {}
    });
  })();
</script>

<%- include('partials/foot') %>
