        return { runCode, melt, mfr, runIndex: index + 1 };
      }).filter(Boolean);
      if (!points.length) return null;

      const mfrValues = points.map((item) => item.mfr).sort((a, b) => a - b);
      const mfrMedian = mfrValues[Math.floor(mfrValues.length / 2)];
      const limitPct = 20;
      const classify = (item) => {
        if (!Number.isFinite(mfrMedian) || mfrMedian === 0) return 'stable';
        const drift = ((item.mfr - mfrMedian) / mfrMedian) * 100;
        if (drift > limitPct) return 'high';
        if (drift < -limitPct) return 'low';
        return 'stable';
      };

      const stable = points.filter((item) => classify(item) === 'stable');
      const high = points.filter((item) => classify(item) === 'high');
      const low = points.filter((item) => classify(item) === 'low');
      const windowPoints = stable.length ? stable : points;
      const recommended = windowPoints.reduce((acc, item) => (
        Math.abs(item.mfr - mfrMedian) < Math.abs(acc.mfr - mfrMedian) ? item : acc
      ));
      const upper = mfrMedian * (1 + limitPct / 100);
      const lower = mfrMedian * (1 - limitPct / 100);

      return { points, mfrMedian, limitPct, stable, high, low, windowPoints, recommended, upper, lower };
