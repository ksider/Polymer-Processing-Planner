<%- include('partials/head', { title: 'Polymer Processing Planner | Qualification Step' }) %>
<%- include('partials/nav') %>
<div class="container">
  <div class="card">
    <div class="card-header card-header-main">
      <a class="back-link" href="<%= `${experimentPath(experimentId)}#qualification` %>" aria-label="Back to experiment qualification">
        <span class="material-symbols-rounded" aria-hidden="true">arrow_back</span>
      </a>
      <div>
        <h1 class="card-title">Step <%= step.step_number %>: <%= stepDef?.name || 'Qualification Step' %></h1>
        <p class="small-note">
          Responsible:
          <span id="qualStepResponsibleLabel">
            <% if (stepAssigneeId) { %>
              <a href="/users/<%= stepAssigneeId %>"><%- formatInline(stepAssigneeLabel || `User #${stepAssigneeId}`) %></a>
            <% } else { %>
              <span>-</span>
            <% } %>
          </span>
        </p>
      </div>
      <div class="section-actions">
        <% if (canAssignEntities) { %>
          <button class="icon-button" type="button" id="openQualSettingsDialog" title="Qualification settings">
            <span class="material-symbols-rounded" aria-hidden="true">edit</span>
          </button>
        <% } %>
      </div>
    </div>
    <div class="run-controls">
      <button class="pure-button pure-button-secondary" type="button" id="openQualFields">Manage fields</button>
      <button class="pure-button pure-button-primary" type="button" id="addRunBtn">Add run</button>
    </div>
    <% if (summaryJson) { %>
      <pre class="qual-summary"><%= summaryJson %></pre>
    <% } %>
  </div>

  <% let summaryData = null; %>
  <% if (summaryJson) { try { summaryData = JSON.parse(summaryJson); } catch { summaryData = null; } } %>
  <% const settings = stepSettings || {}; %>
  <% const fmt = (value, digits = 2) => (typeof value === 'number' && Number.isFinite(value) ? formatNumber(value, digits) : '-'); %>
  <% if (step.step_number === 1) { %>
    <div class="card">
      <div class="card-header">
        <h2 class="card-title">Recommended Baseline from RTD Stability</h2>
      </div>
      <div class="setup-summary">
        <div>
          <div class="small-note">Recommended run</div>
          <div class="setup-value" data-live-step1="recommended_run"><%= summaryData?.recommended_run || '-' %></div>
        </div>
        <div>
          <div class="small-note">Screw RPM</div>
          <div class="setup-value"><span data-live-step1="recommended_screw_rpm"><%= fmt(summaryData?.recommended_screw_rpm, 0) %></span> <span class="small-note">rpm</span></div>
        </div>
        <div>
          <div class="small-note">MFR</div>
          <div class="setup-value"><span data-live-step1="recommended_mfr_g_10min"><%= fmt(summaryData?.recommended_mfr_g_10min) %></span> <span class="small-note">g/10min</span></div>
        </div>
        <div>
          <div class="small-note">Head temp</div>
          <div class="setup-value"><span data-live-step1="recommended_head_temp_c"><%= fmt(summaryData?.recommended_head_temp_c, 1) %></span> <span class="small-note">°C</span></div>
        </div>
        <div>
          <div class="small-note">Mid temp</div>
          <div class="setup-value"><span data-live-step1="recommended_mid_temp_c"><%= fmt(summaryData?.recommended_mid_temp_c, 1) %></span> <span class="small-note">°C</span></div>
        </div>
        <div>
          <div class="small-note">Min stabilization</div>
          <div class="setup-value"><span data-live-step1="recommended_stabilization_time_min"><%= fmt(summaryData?.recommended_stabilization_time_min ?? summaryData?.stabilization_time_min, 1) %></span> <span class="small-note">min</span></div>
        </div>
      </div>
      <div class="small-note" style="margin-top: .75rem;">
        Window estimate:
        screw <strong><span data-live-step1="window_screw_rpm_min"><%= fmt(summaryData?.window_screw_rpm_min, 0) %></span> - <span data-live-step1="window_screw_rpm_max"><%= fmt(summaryData?.window_screw_rpm_max, 0) %></span> rpm</strong>,
        head temp <strong><span data-live-step1="window_head_temp_c_min"><%= fmt(summaryData?.window_head_temp_c_min, 1) %></span> - <span data-live-step1="window_head_temp_c_max"><%= fmt(summaryData?.window_head_temp_c_max, 1) %></span> °C</strong>,
        mid temp <strong><span data-live-step1="window_mid_temp_c_min"><%= fmt(summaryData?.window_mid_temp_c_min, 1) %></span> - <span data-live-step1="window_mid_temp_c_max"><%= fmt(summaryData?.window_mid_temp_c_max, 1) %></span> °C</strong>
      </div>
    </div>
  <% } %>
  <% if (step.step_number === 2) { %>
    <div class="card">
      <div class="card-header">
        <h2 class="card-title">Recommended SME Window</h2>
      </div>
      <div class="setup-summary">
        <div>
          <div class="small-note">Recommended run</div>
          <div class="setup-value" data-live-step2="recommended_run"><%= summaryData?.recommended_run || '-' %></div>
        </div>
        <div>
          <div class="small-note">Screw RPM</div>
          <div class="setup-value"><span data-live-step2="recommended_screw_rpm"><%= fmt(summaryData?.recommended_screw_rpm, 0) %></span> <span class="small-note">rpm</span></div>
        </div>
        <div>
          <div class="small-note">Throughput</div>
          <div class="setup-value"><span data-live-step2="recommended_throughput_kg_h"><%= fmt(summaryData?.recommended_throughput_kg_h, 2) %></span> <span class="small-note">kg/h</span></div>
        </div>
        <div>
          <div class="small-note">SME</div>
          <div class="setup-value"><span data-live-step2="recommended_sme_kj_kg"><%= fmt(summaryData?.recommended_sme_kj_kg, 2) %></span> <span class="small-note">kJ/kg</span></div>
        </div>
        <div>
          <div class="small-note">Melt temp</div>
          <div class="setup-value"><span data-live-step2="recommended_melt_temp_c"><%= fmt(summaryData?.recommended_melt_temp_c, 1) %></span> <span class="small-note">°C</span></div>
        </div>
      </div>
      <div class="small-note" style="margin-top: .75rem;">
        Window estimate:
        SME <strong><span data-live-step2="window_sme_min_kj_kg"><%= fmt(summaryData?.window_sme_min_kj_kg, 2) %></span> - <span data-live-step2="window_sme_max_kj_kg"><%= fmt(summaryData?.window_sme_max_kj_kg, 2) %></span> kJ/kg</strong>,
        screw <strong><span data-live-step2="window_screw_rpm_min"><%= fmt(summaryData?.window_screw_rpm_min, 0) %></span> - <span data-live-step2="window_screw_rpm_max"><%= fmt(summaryData?.window_screw_rpm_max, 0) %></span> rpm</strong>,
        throughput <strong><span data-live-step2="window_throughput_kg_h_min"><%= fmt(summaryData?.window_throughput_kg_h_min, 2) %></span> - <span data-live-step2="window_throughput_kg_h_max"><%= fmt(summaryData?.window_throughput_kg_h_max, 2) %></span> kg/h</strong>
      </div>
    </div>
  <% } %>
  <% if (step.step_number === 3) { %>
    <div class="card">
      <div class="card-header">
        <h2 class="card-title">Setup</h2>
        <div class="setup-actions">
          <button class="pure-button pure-button-secondary" type="button" id="openStep3Setup">Edit setup</button>
        </div>
      </div>
      <div class="setup-summary">
        <div>
          <div class="small-note">Target screw RPM</div>
          <div class="setup-value"><span data-live-step3="target_screw_rpm"><%= fmt(Number(settings.target_screw_rpm), 0) %></span> <span class="small-note">rpm</span></div>
        </div>
      </div>
    </div>
  <% } %>

  <%- include('partials/entity_notes', {
    experimentId: experimentId,
    entityType: 'qualification_step',
    entityId: step.step_number,
    title: `Step ${step.step_number} Notes`,
    canWrite: currentUser && (currentUser.role === 'admin' || currentUser.role === 'manager' || currentUser.role === 'engineer')
  }) %>

  <div class="card">
    <div class="card-header">
      <h2 class="card-title">Runs</h2>
    </div>
    <% const activeFields = fields.filter((field) => field.is_enabled === 1); %>
    <% const inputFields = activeFields.filter((field) => String(field.group_label || '').toLowerCase() === 'inputs'); %>
    <% const measurementFields = activeFields.filter((field) => String(field.group_label || '').toLowerCase() === 'measurements'); %>
    <% const summaryFields = activeFields.filter((field) => !['inputs', 'measurements'].includes(String(field.group_label || '').toLowerCase())); %>
    <% const orderedFields = [...inputFields, ...measurementFields, ...summaryFields]; %>
    <div class="table-scroll">
      <table class="pure-table table-compact" id="compoundingRunsTable">
        <thead>
          <tr>
            <th>Run</th>
            <th>Due date</th>
            <% orderedFields.forEach((field) => { %>
              <th>
                <%- formatInline(field.label) %>
                <% if (field.unit) { %><span class="small-note"> <%= field.unit %></span><% } %>
              </th>
            <% }); %>
            <th>Done</th>
            <th>Exclude</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% if (runs.length === 0) { %>
            <tr><td colspan="<%= orderedFields.length + 5 %>">No runs yet.</td></tr>
          <% } %>
          <% runs.forEach((run) => { %>
            <% const values = runValueMap[String(run.id)] || {}; %>
            <tr data-run-row data-run-id="<%= run.id %>">
              <td><strong><%= run.run_code %></strong></td>
              <td><input type="date" data-run-due value="<%= run.due_at || '' %>"></td>
              <% orderedFields.forEach((field) => { %>
                <% const value = values[String(field.id)]; %>
                <td>
                  <% if (field.is_derived) { %>
                    <span class="small-note" data-derived-code="<%= field.code %>">
                      <% if (field.field_type === 'number') { %>
                        <%= formatNumber(value?.value_real) %>
                      <% } else if (field.field_type === 'tag') { %>
                        <%= value?.value_tags_json || '-' %>
                      <% } else { %>
                        <%= value?.value_text || '-' %>
                      <% } %>
                    </span>
                  <% } else if (field.field_type === 'boolean') { %>
                    <input type="checkbox" data-field-id="<%= field.id %>" data-field-type="boolean" <%= value?.value_real === 1 ? 'checked' : '' %>>
                  <% } else if (field.field_type === 'number') { %>
                    <input type="number" step="any" data-field-id="<%= field.id %>" data-field-type="number" value="<%= value?.value_real ?? '' %>">
                  <% } else if (field.field_type === 'tag') { %>
                    <% let selected = []; %>
                    <% if (value?.value_tags_json) { try { const parsed = JSON.parse(value.value_tags_json); if (Array.isArray(parsed)) selected = parsed.map(String); } catch {} } %>
                    <input type="text" data-field-id="<%= field.id %>" data-field-type="tag" placeholder="a,b,c" value="<%- formatInline(selected.join(', ')) %>">
                  <% } else { %>
                    <input type="text" data-field-id="<%= field.id %>" data-field-type="text" value="<%- formatInline(value?.value_text || '') %>">
                  <% } %>
                </td>
              <% }); %>
              <td><input type="checkbox" data-flag="done" <%= run.done === 1 ? 'checked' : '' %>></td>
              <td><input type="checkbox" data-flag="exclude" <%= run.exclude_from_analysis === 1 ? 'checked' : '' %>></td>
              <td>
                <button class="icon-button danger" type="button" data-run-delete title="Delete row">
                  <span class="material-symbols-rounded" aria-hidden="true">delete</span>
                </button>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <% if (step.step_number === 1) { %>
    <div class="card">
      <div class="card-header">
        <h2 class="card-title">MFR vs Screw RPM</h2>
      </div>
      <div class="chart-card">
        <div id="compoundingStep1Chart" style="width: 100%; height: 320px;"></div>
      </div>
    </div>
  <% } %>
  <% if (step.step_number === 2) { %>
    <div class="card">
      <div class="card-header">
        <h2 class="card-title">SME vs Screw RPM (by Melt Temperature)</h2>
      </div>
      <div class="chart-card">
        <div id="compoundingStep2Chart" style="width: 100%; height: 340px;"></div>
      </div>
      <p class="small-note" id="step2RecommendationReason" style="margin-top: .75rem;">
        Recommendation reason will appear here after data entry.
      </p>
    </div>
  <% } %>
  <% if (step.step_number === 3) { %>
    <div class="card">
      <div class="card-header">
        <h2 class="card-title">Recommendation (MFR Stability)</h2>
      </div>
      <div class="recommendation-summary">
        <div class="recommendation-item">
          <div class="small-note">Recommended run</div>
          <div class="recommendation-value" data-live-step3="recommended_run"><%= summaryData?.recommended_run || '-' %></div>
        </div>
        <div class="recommendation-item">
          <div class="small-note">Recommended melt temp</div>
          <div class="recommendation-value"><span data-live-step3="recommended_melt_temp_c"><%= fmt(summaryData?.recommended_melt_temp_c, 1) %></span> <span class="small-note">°C</span></div>
        </div>
        <div class="recommendation-item">
          <div class="small-note">Recommended MFR</div>
          <div class="recommendation-value"><span data-live-step3="recommended_mfr_g_10min"><%= fmt(summaryData?.recommended_mfr_g_10min, 2) %></span> <span class="small-note">g/10min</span></div>
        </div>
        <div class="recommendation-item">
          <div class="small-note">Melt temp window</div>
          <div class="recommendation-value"><span data-live-step3="melt_temp_min_c"><%= fmt(summaryData?.melt_temp_min_c, 1) %></span> - <span data-live-step3="melt_temp_max_c"><%= fmt(summaryData?.melt_temp_max_c, 1) %></span> <span class="small-note">°C</span></div>
        </div>
        <div class="recommendation-item">
          <div class="small-note">MFR median / limit</div>
          <div class="recommendation-value"><span data-live-step3="mfr_median_g_10min"><%= fmt(summaryData?.mfr_median_g_10min, 2) %></span> <span class="small-note">g/10min</span> / <span data-live-step3="mfr_deviation_limit_pct"><%= fmt(summaryData?.mfr_deviation_limit_pct, 0) %></span><span class="small-note">%</span></div>
        </div>
        <div class="recommendation-item">
          <div class="small-note">Outliers (high/low)</div>
          <div class="recommendation-value"><span data-live-step3="mfr_rising_outlier_count"><%= fmt(summaryData?.mfr_rising_outlier_count, 0) %></span> / <span data-live-step3="mfr_falling_outlier_count"><%= fmt(summaryData?.mfr_falling_outlier_count, 0) %></span></div>
        </div>
      </div>
      <div class="chart-card" style="margin-top: 1rem;">
        <div id="compoundingStep3Chart" style="width: 100%; height: 340px;"></div>
      </div>
      <div class="chart-card" style="margin-top: .75rem;">
        <div id="compoundingStep3DeviationChart" style="width: 100%; height: 260px;"></div>
      </div>
      <p class="small-note" id="step3RecommendationReason" style="margin-top: .75rem;">
        <%= summaryData?.mfr_interpretation || 'MFR stability interpretation will appear after data entry.' %>
      </p>
    </div>
  <% } %>
</div>

<% if (canAssignEntities) { %>
  <dialog class="modal-frame" id="qualSettingsDialog">
    <div class="modal-header">
      <strong>Qualification settings</strong>
      <button class="pure-button" type="button" data-close>Close</button>
    </div>
    <form class="pure-form" id="qualSettingsForm" action="/experiments/<%= experimentId %>/qualification/<%= step.step_number %>/assignee" method="post">
      <div class="modal-body">
        <label for="qualStepAssigneeInput">Responsible</label>
        <select id="qualStepAssigneeInput" name="assignee_user_id">
          <option value="">Unassigned</option>
          <% assignableUsers.forEach((user) => { %>
            <option value="<%= user.id %>" <%= stepAssigneeId === user.id ? 'selected' : '' %>>
              <%= user.name || user.email %> (<%= user.role || 'user' %>)
            </option>
          <% }); %>
        </select>
      </div>
      <div class="modal-footer">
        <span class="small-note" data-autosave-status></span>
        <button class="pure-button" type="button" data-close>Cancel</button>
        <button class="pure-button pure-button-primary" type="submit">Save</button>
      </div>
    </form>
  </dialog>
<% } %>

<% if (step.step_number === 3) { %>
  <dialog class="modal-frame" id="step3SetupDialog">
    <div class="modal-header">
      <strong>Step 3 setup</strong>
      <button class="pure-button" type="button" data-close>Close</button>
    </div>
    <form class="pure-form" id="step3SetupForm" action="/experiments/<%= experimentId %>/qualification/<%= step.step_number %>/settings" method="post">
      <div class="modal-body">
        <label for="targetScrewRpmInput">Target screw RPM</label>
        <input id="targetScrewRpmInput" name="target_screw_rpm" type="number" step="1" min="0" value="<%= settings.target_screw_rpm ?? '' %>" />
        <p class="small-note">Used as fixed setup value for this step, not as a run column.</p>
      </div>
      <div class="modal-footer">
        <span class="small-note" data-autosave-status></span>
        <button class="pure-button" type="button" data-close>Close</button>
      </div>
    </form>
  </dialog>
<% } %>

<dialog class="modal-frame" id="qualFieldDialog">
  <div class="modal-header">
    <strong>Qualification fields</strong>
    <button class="pure-button" type="button" data-close>Close</button>
  </div>
  <div class="modal-body">
    <div class="field-toolbar">
      <label>
        Library
        <select id="qualLibrarySelect">
          <option value="">Select parameter…</option>
          <% globalParams.forEach((param) => { %>
            <option value="<%= param.id %>">
              <%- formatInline(param.label) %> (<%= param.code %>)
            </option>
          <% }); %>
        </select>
      </label>
      <button class="pure-button" type="button" id="qualImportField">Add from library</button>
      <a class="pure-button pure-button-secondary" href="/param-library">Open library</a>
    </div>
    <table class="pure-table table-compact qual-field-table">
      <thead>
        <tr>
          <th>Code</th>
          <th>Label</th>
          <th>Type</th>
          <th>Unit</th>
          <th>Required</th>
          <th>Enabled</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% fields.forEach((field) => { %>
          <tr data-field-row data-field-id="<%= field.id %>">
            <td><input data-field-code value="<%= field.code %>" <%= field.is_derived ? 'readonly' : '' %>></td>
            <td><input data-field-label value="<%- formatInline(field.label) %>" <%= field.is_derived ? 'readonly' : '' %>></td>
            <td>
              <select data-field-type <%= field.is_derived ? 'disabled' : '' %>>
                <option value="number" <%= field.field_type === 'number' ? 'selected' : '' %>>number</option>
                <option value="text" <%= field.field_type === 'text' ? 'selected' : '' %>>text</option>
                <option value="tag" <%= field.field_type === 'tag' ? 'selected' : '' %>>tag</option>
                <option value="boolean" <%= field.field_type === 'boolean' ? 'selected' : '' %>>boolean</option>
              </select>
            </td>
            <td><input data-field-unit value="<%= field.unit || '' %>" <%= field.is_derived ? 'readonly' : '' %>></td>
            <td><input type="checkbox" data-field-required <%= field.required === 1 ? 'checked' : '' %> <%= field.is_derived ? 'disabled' : '' %>></td>
            <td><input type="checkbox" data-field-enabled <%= field.is_enabled === 1 ? 'checked' : '' %> <%= field.is_derived ? 'disabled' : '' %>></td>
            <td>
              <% if (!field.is_derived) { %>
                <button class="icon-button danger" type="button" data-field-delete title="Delete field">
                  <span class="material-symbols-rounded" aria-hidden="true">delete</span>
                </button>
              <% } %>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>

    <div class="card" style="margin-top: 1rem;">
      <h3 class="card-title">Custom Field</h3>
      <form class="pure-form pure-form-stacked" id="qualCustomFieldForm">
        <div class="field-grid">
          <div>
            <label>Code</label>
            <input type="text" name="code" placeholder="custom_param" required>
          </div>
          <div>
            <label>Label</label>
            <input type="text" name="label" placeholder="Custom Parameter" required>
          </div>
          <div>
            <label>Unit</label>
            <input type="text" name="unit" placeholder="">
          </div>
          <div>
            <label>Type</label>
            <select name="field_type">
              <option value="number" selected>Number</option>
              <option value="text">Text</option>
              <option value="tag">Tag</option>
              <option value="boolean">Boolean</option>
            </select>
          </div>
        </div>
        <button class="pure-button pure-button-primary" type="submit">Add Field</button>
      </form>
    </div>
  </div>
</dialog>

<script src="/vendor/echarts/dist/echarts.min.js"></script>
<script>
  (function () {
    const experimentId = <%= experimentId %>;
    const stepNumber = <%= step.step_number %>;
    const table = document.getElementById('compoundingRunsTable');
    const fieldIdByCode = <%- JSON.stringify(Object.fromEntries(fields.map((field) => [field.code, field.id]))) %>;
    const qualSettingsDialog = document.getElementById('qualSettingsDialog');
    const qualSettingsForm = document.getElementById('qualSettingsForm');
    const step3SetupDialog = document.getElementById('step3SetupDialog');
    const step3SetupForm = document.getElementById('step3SetupForm');
    const qualStepAssigneeInput = document.getElementById('qualStepAssigneeInput');
    const qualStepResponsibleLabel = document.getElementById('qualStepResponsibleLabel');
    const qualAssignableUserById = new Map(<%- JSON.stringify((assignableUsers || []).map((user) => [String(user.id), user.name || user.email])) %>);

    const post = async (url, body) => {
      if (window.IMPlanner?.postForm) {
        return window.IMPlanner.postForm(url, body);
      }
      const response = await fetch(url, { method: 'POST', body });
      if (!response.ok) throw new Error(`Request failed (${response.status})`);
      return null;
    };

    const saveTimers = new Map();
    const queueSave = (key, fn) => {
      if (saveTimers.has(key)) clearTimeout(saveTimers.get(key));
      const timer = setTimeout(async () => {
        try { await fn(); } catch {}
      }, 180);
      saveTimers.set(key, timer);
    };
    const parseNumber = (raw) => {
      if (raw == null) return null;
      const text = String(raw).trim().replace(',', '.');
      if (!text) return null;
      const num = Number(text);
      return Number.isFinite(num) ? num : null;
    };
    const numFromRow = (row, code) => {
      const fieldId = fieldIdByCode?.[code];
      if (!fieldId) return null;
      const input = row.querySelector(`[data-field-id="${fieldId}"]`);
      if (!input) return null;
      return parseNumber(input.value);
    };
    const fmtLive = (value, digits = 2) => {
      if (!Number.isFinite(value)) return '-';
      const num = Number(value);
      if (digits <= 0) return String(Math.round(num));
      return num.toFixed(digits).replace(/\.?0+$/, '');
    };
    const setLive = (scope, key, value, digits = 2) => {
      const node = document.querySelector(`[${scope}="${key}"]`);
      if (!node) return;
      if (typeof value === 'number') {
        node.textContent = fmtLive(value, digits);
        return;
      }
      node.textContent = value == null || value === '' ? '-' : String(value);
    };
    const setReasonText = (text) => {
      const node = document.getElementById('step2RecommendationReason');
      if (!node) return;
      node.textContent = text || 'Recommendation reason is unavailable.';
    };
