        const runCode = row.querySelector('td strong')?.textContent?.trim() || '';
        const rpm = numFromRow(row, 'screw_rpm');
        const throughput = numFromRow(row, 'throughput_kg_h');
        const torque = numFromRow(row, 'torque_pct');
        const current = numFromRow(row, 'motor_current_a');
        const driveSignal = Number.isFinite(torque) && torque !== 0 ? torque : current;
        const melt = numFromRow(row, 'melt_temp_c');
        if (!Number.isFinite(rpm) || !Number.isFinite(throughput) || throughput <= 0 || !Number.isFinite(driveSignal)) return null;
        const sme = (driveSignal * rpm) / throughput * 0.01;
        return { runCode, rpm, throughput, sme, melt };
      }).filter(Boolean);
      if (!candidates.length) {
        setReasonText('No valid runs yet. Fill Screw RPM, Throughput, and Torque or Motor current.');
        return;
      }
      const smeValues = candidates.map((item) => item.sme).sort((a, b) => a - b);
      const q1 = quantileSorted(smeValues, 0.25);
      const q3 = quantileSorted(smeValues, 0.75);
      const median = quantileSorted(smeValues, 0.5);
      const windowBase = smeValues.length >= 4
        ? candidates.filter((item) => item.sme >= q1 && item.sme <= q3)
        : candidates;
      const windowCandidates = windowBase.length ? windowBase : candidates;
      const score = (item) => {
        const smeDrift = median !== 0 ? Math.abs((item.sme - median) / median) * 100 : Math.abs(item.sme - median);
        const meltPenalty = Number.isFinite(item.melt) ? Math.max(item.melt, 0) * 0.001 : 0;
        return smeDrift + meltPenalty;
      };
      const best = windowCandidates.reduce((a, b) => (score(b) < score(a) ? b : a));
      const minBy = (arr, key) => Math.min(...arr.map((item) => item[key]).filter((v) => Number.isFinite(v)));
      const maxBy = (arr, key) => Math.max(...arr.map((item) => item[key]).filter((v) => Number.isFinite(v)));
      setLive('data-live-step2', 'recommended_run', best.runCode);
