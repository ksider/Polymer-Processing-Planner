      setLive('data-live-step2', 'window_sme_min_kj_kg', minBy(windowCandidates, 'sme'), 2);
      setLive('data-live-step2', 'window_sme_max_kj_kg', maxBy(windowCandidates, 'sme'), 2);
      setLive('data-live-step2', 'window_screw_rpm_min', minBy(windowCandidates, 'rpm'), 0);
      setLive('data-live-step2', 'window_screw_rpm_max', maxBy(windowCandidates, 'rpm'), 0);
      setLive('data-live-step2', 'window_throughput_kg_h_min', minBy(windowCandidates, 'throughput'), 2);
      setLive('data-live-step2', 'window_throughput_kg_h_max', maxBy(windowCandidates, 'throughput'), 2);

      const bestScore = score(best);
      const iqrMode = smeValues.length >= 4 ? 'IQR window' : 'full sample';
      setReasonText(
        `Selected ${best.runCode}: SME ${fmtLive(best.sme, 2)} is closest to median ${fmtLive(median, 2)} ` +
        `inside ${iqrMode} [${fmtLive(q1, 2)}..${fmtLive(q3, 2)}], score ${fmtLive(bestScore, 2)} ` +
