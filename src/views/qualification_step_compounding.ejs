      const scoreLimit = best.score * 1.25;
      const windowPoints = candidates.filter((item) => item.score <= scoreLimit);
      const minBy = (arr, key) => Math.min(...arr.map((item) => item[key]).filter((v) => Number.isFinite(v)));
      const maxBy = (arr, key) => Math.max(...arr.map((item) => item[key]).filter((v) => Number.isFinite(v)));
      setLive('data-live-step1', 'recommended_run', best.runCode);
      setLive('data-live-step1', 'recommended_screw_rpm', best.screw, 0);
      setLive('data-live-step1', 'recommended_mfr_g_10min', best.mfr, 2);
      setLive('data-live-step1', 'recommended_head_temp_c', best.headTemp, 1);
