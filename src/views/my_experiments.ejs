<%- include('partials/head', { title: 'Polymer Processing Planner | My Experiments' }) %>
<%- include('partials/nav') %>
<div class="container">
  <div class="card">
    <h1 class="card-title">My Experiments</h1>
    <p class="small-note">Experiments assigned to you.</p>
  </div>

  <div class="card">
    <h2 class="card-title">List</h2>
    <table class="pure-table table-compact">
      <thead>
        <tr>
          <th>ID</th>
          <th>Name</th>
          <th>Process</th>
          <th>Owner</th>
          <th>Status</th>
          <th>Created</th>
        </tr>
      </thead>
      <tbody>
        <% if (experiments.length === 0) { %>
          <tr>
            <td colspan="6">No experiments assigned.</td>
          </tr>
        <% } %>
        <% experiments.forEach((exp) => { %>
          <tr>
            <td><%= exp.id %></td>
            <td><a href="<%= experimentPath(exp) %>"><%- formatInline(exp.name) %></a></td>
            <td>
              <div><%- formatInline(exp.process_label) %></div>
              <div class="small-note"><%- formatInline(exp.process_type_label) %></div>
            </td>
            <td>
              <% if (exp.owner_user_id) { %>
                <a href="/users/<%= exp.owner_user_id %>"><%= exp.owner_label %></a>
              <% } else { %>
                <%= exp.owner_label %>
              <% } %>
            </td>
            <td><span class="status-pill status-<%= exp.status %>"><%= exp.statusLabel %></span></td>
            <td><%= new Date(exp.created_at).toLocaleDateString() %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
<%- include('partials/foot') %>
