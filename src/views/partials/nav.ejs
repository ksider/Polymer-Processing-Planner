<nav class="top-nav">
  <div class="nav-brand">
    <% if (breadcrumbs && breadcrumbs.length > 0) { %>
      <div class="breadcrumb breadcrumb-inline">
        <% breadcrumbs.forEach((crumb, index) => { %>
          <% if (index > 0) { %>
            <span class="breadcrumb-sep">/</span>
          <% } %>
          <% if (index < breadcrumbs.length - 1 && crumb.href) { %>
            <a href="<%= crumb.href %>"><%= crumb.label %></a>
          <% } else { %>
            <span class="breadcrumb-current"><%= crumb.label %></span>
          <% } %>
        <% }); %>
      </div>
    <% } else { %>
      Polymer Processing Planner
    <% } %>
  </div>
  <div class="nav-links">
    <a href="/recipes">Recipes</a>
    <% if (currentUser && (currentUser.role === "admin" || currentUser.role === "manager" || currentUser.role === "engineer")) { %>
    <% } %>
    <a href="/machines">Machines</a>
  </div>
  <% if (currentUser) { %>
    <div class="nav-auth">
      <a
        class="nav-bell"
        href="/messages"
        title="Messages"
        data-messages-popover-toggle
        aria-haspopup="dialog"
        aria-expanded="false"
      >
        <span class="material-symbols-rounded" aria-hidden="true">notifications</span>
        <% if (unreadNotifications && unreadNotifications > 0) { %>
          <span class="nav-bell-badge" data-messages-unread-badge><%= unreadNotifications > 99 ? '99+' : unreadNotifications %></span>
        <% } %>
      </a>
      <div class="messages-popover" data-messages-popover hidden>
        <div class="messages-popover-head">
          <strong>Unread messages</strong>
          <button class="pure-button button-sm" type="button" data-messages-read-all>Mark all read</button>
        </div>
        <div class="messages-popover-body" data-messages-popover-body>
          <div class="small-note">Loading...</div>
        </div>
        <div class="messages-popover-foot">
          <a class="pure-button pure-button-primary" href="/messages">Open messages</a>
        </div>
      </div>
      <span class="nav-user">
        <a href="/me">
          <img class="nav-user-avatar" src="<%= avatarUrl(currentUser.id) %>" alt="<%= currentUser.name ? currentUser.name : currentUser.email %> avatar">
          <span><%= currentUser.name ? currentUser.name : currentUser.email %></span>
        </a>
      </span>
      <form method="post" action="/auth/logout">
        <button class="pure-button pure-button-primary" type="submit">Logout</button>
      </form>
    </div>
  <% } %>
</nav>
