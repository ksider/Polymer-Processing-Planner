<%- include('partials/head', { title: title }) %>
<%- include('partials/nav') %>
<div class="container">
  <div class="card profile-hero">
    <div class="profile-hero-row">
      <div>
        <h1 class="card-title profile-name" id="profileName">
          <%= currentUser?.name || currentUser?.email || 'Profile' %>
        </h1>
        <div class="small-note profile-meta" id="profileMeta">
          <%= (currentUser?.role || 'user') %> · <%= currentUser?.email || '-' %>
        </div>
      </div>
      <button class="icon-btn icon-only" type="button" id="openProfileDialog" title="Edit profile">
        <span class="material-symbols-rounded">edit</span>
      </button>
    </div>
  </div>

  <dialog class="modal-frame" id="profileDialog">
    <div class="modal-header">
      <strong>Profile settings</strong>
      <button class="icon-btn icon-only" type="button" data-close title="Close">
        <span class="material-symbols-rounded">close</span>
      </button>
    </div>
    <div class="modal-body">
      <% if (error) { %>
        <div class="auth-error"><%= error %></div>
      <% } %>
      <% if (notice) { %>
        <div class="auth-error"><%= notice %></div>
      <% } %>
      <form class="pure-form pure-form-stacked" action="/me/name" method="post">
        <label for="name">Name</label>
        <input id="name" name="name" type="text" value="<%= currentUser?.name ?? '' %>" placeholder="Your name">
        <button class="pure-button pure-button-primary" type="submit">Update name</button>
      </form>
      <form class="pure-form pure-form-stacked" action="/me/password" method="post" style="margin-top: 1rem;">
        <label for="current_password">Current password</label>
        <input id="current_password" name="current_password" type="password" autocomplete="current-password" required>
        <label for="new_password">New password</label>
        <input id="new_password" name="new_password" type="password" autocomplete="new-password" required>
        <label for="confirm_password">Confirm password</label>
        <input id="confirm_password" name="confirm_password" type="password" autocomplete="new-password" required>
        <button class="pure-button pure-button-primary" type="submit">Update password</button>
      </form>
    </div>
  </dialog>

  <div class="card">
    <h2 class="card-title">My Calendar</h2>
    <div class="small-note">Tasks and runs assigned to you. Select entities with Shift/Cmd/Ctrl + click, then drag one selected event or use Move selected.</div>
    <div class="calendar-tools">
      <span id="calendarSelectionCount" class="small-note">Selected: 0</span>
      <button class="pure-button" type="button" id="calendarClearSelection">Clear selection</button>
      <input class="pure-input" type="date" id="calendarBatchDate">
      <button class="pure-button pure-button-primary" type="button" id="calendarBatchMove">Move selected</button>
    </div>
    <div id="myCalendar" class="calendar-host"></div>
  </div>

  <dialog class="modal-frame" id="calendarEventDialog">
    <div class="modal-header">
      <strong id="calendarEventTitle">Calendar event</strong>
      <button class="icon-btn icon-only" type="button" data-close title="Close">
        <span class="material-symbols-rounded">close</span>
      </button>
    </div>
    <div class="modal-body">
      <div><strong>Type:</strong> <span id="calendarEventType">-</span></div>
      <div><strong>Status:</strong> <span id="calendarEventStatus">-</span></div>
      <div><strong>Due:</strong> <span id="calendarEventDue">-</span></div>
      <div><strong>Responsible:</strong> <span id="calendarEventOwner">-</span></div>
      <div><strong>Entity:</strong> <span id="calendarEventEntity">-</span></div>
      <div><strong>Process:</strong> <span id="calendarEventProcess">-</span></div>
      <div class="section-actions" style="margin-top:0.75rem;">
        <a class="pure-button pure-button-primary" id="calendarEventDetailLink" href="#">Open run/task</a>
        <a class="pure-button" id="calendarEventEntityLink" href="#">Open entity</a>
      </div>
    </div>
  </dialog>

  <div class="card">
    <h2 class="card-title">My Tasks</h2>
    <table class="pure-table table-compact">
      <thead>
        <tr>
          <th>Task</th>
          <th>Experiment</th>
          <th>Status</th>
          <th>Due</th>
          <th>%</th>
        </tr>
      </thead>
      <tbody>
        <% if (!tasks || tasks.length === 0) { %>
          <tr>
            <td colspan="5">No tasks assigned.</td>
          </tr>
        <% } %>
        <% tasks.forEach((task) => { %>
          <tr>
            <td><%= task.title %></td>
            <td><a href="/experiments/<%= task.experiment_id %>"><%- formatInline(task.experiment_name) %></a></td>
            <td><%= task.status %></td>
            <td><%= task.due_at ? new Date(task.due_at).toLocaleDateString() : '-' %></td>
            <td><%= typeof task.progress_percent === 'number' ? `${task.progress_percent}%` : '-' %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

  <div class="card">
    <h2 class="card-title">Assigned Entities</h2>
    <table class="pure-table table-compact">
      <thead>
        <tr>
          <th>Entity</th>
          <th>Experiment</th>
          <th>Assigned at</th>
          <th>Assigned by</th>
        </tr>
      </thead>
      <tbody>
        <% if (!assignedEntities || assignedEntities.length === 0) { %>
          <tr>
            <td colspan="4">No entity assignments.</td>
          </tr>
        <% } %>
        <% assignedEntities.forEach((item) => { %>
          <tr>
            <td><a href="<%= item.entityPath %>"><%- formatInline(item.entityTitle) %></a></td>
            <td><a href="/experiments/<%= item.experiment_id %>"><%- formatInline(item.experiment_name) %></a></td>
            <td><%= new Date(item.updated_at || item.assigned_at).toLocaleString() %></td>
            <td><%- formatInline(item.assigned_by_name || item.assigned_by_email || '-') %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

  <div class="card" id="notifications">
    <div class="card-header">
      <h2 class="card-title">Notifications</h2>
      <form class="pure-form" action="/me/notifications/read-all" method="post">
        <button class="pure-button" type="submit">Mark all as read</button>
      </form>
    </div>
    <table class="pure-table table-compact">
      <thead>
        <tr>
          <th>Status</th>
          <th>Message</th>
          <th>Time</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% if (!notifications || notifications.length === 0) { %>
          <tr>
            <td colspan="4">No notifications.</td>
          </tr>
        <% } %>
        <% notifications.forEach((note) => { %>
          <tr>
            <td><span class="status-pill status-<%= note.status === 'unread' ? 'in_progress' : 'done' %>"><%= note.status %></span></td>
            <td>
              <strong><%- formatInline(note.title) %></strong>
              <% if (note.body) { %>
                <div class="small-note"><%- formatInline(note.body) %></div>
              <% } %>
              <% if (note.path) { %>
                <div><a href="<%= note.path %>">Open</a></div>
              <% } %>
            </td>
            <td><%= new Date(note.created_at).toLocaleString() %></td>
            <td>
              <% if (note.status === 'unread') { %>
                <form class="pure-form" action="/me/notifications/<%= note.id %>/read" method="post">
                  <button class="pure-button pure-button-secondary" type="submit">Mark read</button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

  <div class="card">
    <h2 class="card-title">My Experiments</h2>
    <table class="pure-table table-compact">
      <thead>
        <tr>
          <th>ID</th>
          <th>Name</th>
          <th>Status</th>
          <th>Created</th>
        </tr>
      </thead>
      <tbody>
        <% if (experiments.length === 0) { %>
          <tr>
            <td colspan="4">No experiments assigned.</td>
          </tr>
        <% } %>
        <% experiments.forEach((exp) => { %>
          <tr>
            <td><%= exp.id %></td>
            <td><a href="<%= experimentPath(exp) %>"><%- formatInline(exp.name) %></a></td>
            <td><span class="status-pill status-<%= exp.status %>"><%= exp.statusLabel %></span></td>
            <td><%= new Date(exp.created_at).toLocaleDateString() %></td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>
<%- include('partials/foot') %>
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.15/index.global.min.js"></script>
<script>
  const renderUserCalendar = () => {
    const host = document.getElementById('myCalendar');
    if (!host || !window.FullCalendar) return;
    host.addEventListener('selectstart', (event) => {
      event.preventDefault();
    });
    host.addEventListener('mousedown', (event) => {
      const target = event.target;
      if (target instanceof HTMLInputElement || target instanceof HTMLTextAreaElement) return;
      event.preventDefault();
    });
    const selectedCountEl = document.getElementById('calendarSelectionCount');
    const clearSelectionBtn = document.getElementById('calendarClearSelection');
    const batchDateInput = document.getElementById('calendarBatchDate');
    const batchMoveBtn = document.getElementById('calendarBatchMove');
    const eventDialog = document.getElementById('calendarEventDialog');
    const eventTitle = document.getElementById('calendarEventTitle');
    const eventType = document.getElementById('calendarEventType');
    const eventStatus = document.getElementById('calendarEventStatus');
    const eventDue = document.getElementById('calendarEventDue');
    const eventOwner = document.getElementById('calendarEventOwner');
    const eventEntity = document.getElementById('calendarEventEntity');
    const eventProcess = document.getElementById('calendarEventProcess');
    const eventDetailLink = document.getElementById('calendarEventDetailLink');
    const eventEntityLink = document.getElementById('calendarEventEntityLink');
    const selectedEventIds = new Set();
    const eventElementMap = new Map();
    let lassoEl = null;
    let lassoActive = false;
    let lassoMoved = false;
    let lassoStartX = 0;
    let lassoStartY = 0;
    let lassoBaseSelection = new Set();

    const toDateOnly = (date) => {
      if (!(date instanceof Date) || Number.isNaN(date.getTime())) return '';
      const y = date.getFullYear();
      const m = String(date.getMonth() + 1).padStart(2, '0');
      const d = String(date.getDate()).padStart(2, '0');
      return `${y}-${m}-${d}`;
    };
    const addDays = (date, days) => {
      if (!(date instanceof Date) || Number.isNaN(date.getTime())) return null;
      const next = new Date(date.getTime());
      next.setDate(next.getDate() + days);
      return next;
    };
    const updateSelectionCount = () => {
      if (selectedCountEl) selectedCountEl.textContent = `Selected: ${selectedEventIds.size}`;
    };
    const refreshSelectionUi = (calendar) => {
      const availableIds = new Set(eventElementMap.keys());
      Array.from(selectedEventIds.values()).forEach((id) => {
        if (!availableIds.has(String(id))) selectedEventIds.delete(id);
      });
      updateSelectionCount();
      applySelectionToEvents();
    };
    const intersectsRect = (a, b) => {
      return !(a.right < b.left || a.left > b.right || a.bottom < b.top || a.top > b.bottom);
    };
    const applySelectionToEvents = () => {
      const applySelectedStyle = (node, selected) => {
        if (!(node instanceof HTMLElement)) return;
        if (selected) {
          node.style.borderColor = '#d32f2f';
          node.style.boxShadow = '';
          node.style.outline = '';
          node.style.outlineOffset = '';
          node.style.transform = '';
          node.style.zIndex = '';
          node.style.filter = '';
        } else {
          node.style.borderColor = '';
          node.style.boxShadow = '';
          node.style.outline = '';
          node.style.outlineOffset = '';
          node.style.transform = '';
          node.style.zIndex = '';
          node.style.filter = '';
        }
      };
      eventElementMap.forEach((elements, eventId) => {
        const isSelected = selectedEventIds.has(eventId);
        elements.forEach((el) => {
          el.classList.toggle('calendar-event-selected', isSelected);
          const innerEvent = el.matches('.fc-event') ? el : el.querySelector('.fc-event');
          if (innerEvent) innerEvent.classList.toggle('calendar-event-selected', isSelected);
          applySelectedStyle(el, isSelected);
          applySelectedStyle(innerEvent, isSelected);
        });
      });
    };
    const clearSelection = (calendar) => {
      selectedEventIds.clear();
      refreshSelectionUi(calendar);
    };
    const patchMove = async (eventId, day) => {
      const resp = await fetch(`/calendar/events/${encodeURIComponent(eventId)}/move`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ starts_at: day })
      });
      if (!resp.ok) throw new Error('move failed');
    };
    const openEventDetails = (event) => {
      if (!eventDialog) return;
      const props = event.extendedProps || {};
      if (eventTitle) eventTitle.textContent = event.title || 'Calendar event';
      if (eventType) eventType.textContent = props.kindLabel || '-';
      if (eventStatus) eventStatus.textContent = props.status || '-';
      if (eventDue) eventDue.textContent = event.start ? new Date(event.start).toLocaleDateString() : '-';
      if (eventOwner) eventOwner.textContent = props.ownerLabel || '-';
      if (eventEntity) eventEntity.textContent = props.entityLabel || '-';
      if (eventProcess) eventProcess.textContent = props.processName || '-';
      if (eventDetailLink) eventDetailLink.href = props.detailUrl || event.url || '#';
      if (eventEntityLink) eventEntityLink.href = props.entityUrl || '#';
      if (typeof eventDialog.showModal === 'function') eventDialog.showModal();
    };
    const clearLasso = () => {
      if (lassoEl && lassoEl.parentNode) lassoEl.parentNode.removeChild(lassoEl);
      lassoEl = null;
      lassoActive = false;
      lassoMoved = false;
    };
    const updateLassoSelection = (calendar, clientX, clientY) => {
      if (!lassoEl) return;
      const hostRect = host.getBoundingClientRect();
      const left = Math.min(lassoStartX, clientX);
      const top = Math.min(lassoStartY, clientY);
      const right = Math.max(lassoStartX, clientX);
      const bottom = Math.max(lassoStartY, clientY);
      const width = right - left;
      const height = bottom - top;
      lassoEl.style.left = `${left - hostRect.left}px`;
      lassoEl.style.top = `${top - hostRect.top}px`;
      lassoEl.style.width = `${width}px`;
      lassoEl.style.height = `${height}px`;
      if (width > 3 || height > 3) lassoMoved = true;

      const lassoRect = { left, top, right, bottom };
      const nextSelection = new Set(lassoBaseSelection);
      eventElementMap.forEach((elements, eventId) => {
        const hit = elements.some((el) => intersectsRect(el.getBoundingClientRect(), lassoRect));
        if (hit) nextSelection.add(eventId);
      });
      selectedEventIds.clear();
      nextSelection.forEach((id) => selectedEventIds.add(id));
      refreshSelectionUi(calendar);
    };
    const startLasso = (calendar, event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      if (target.closest('.fc-event')) return;
      if (target.closest('.fc-button')) return;
      if (target.closest('.calendar-tools')) return;
      if (event.button !== 0) return;

      const additive = Boolean(event.shiftKey || event.metaKey || event.ctrlKey);
      if (additive) lassoBaseSelection = new Set(selectedEventIds);
      else {
        lassoBaseSelection = new Set();
        selectedEventIds.clear();
        refreshSelectionUi(calendar);
      }

      lassoActive = true;
      lassoMoved = false;
      lassoStartX = event.clientX;
      lassoStartY = event.clientY;
      lassoEl = document.createElement('div');
      lassoEl.className = 'calendar-lasso';
      host.appendChild(lassoEl);
      updateLassoSelection(calendar, event.clientX, event.clientY);
      event.preventDefault();

      const onMove = (moveEvent) => {
        if (!lassoActive) return;
        updateLassoSelection(calendar, moveEvent.clientX, moveEvent.clientY);
      };
      const onUp = (upEvent) => {
        if (!lassoActive) return;
        updateLassoSelection(calendar, upEvent.clientX, upEvent.clientY);
        if (!lassoMoved && !additive) {
          selectedEventIds.clear();
          refreshSelectionUi(calendar);
        }
        clearLasso();
        window.removeEventListener('pointermove', onMove);
        window.removeEventListener('pointerup', onUp);
      };
      window.addEventListener('pointermove', onMove);
      window.addEventListener('pointerup', onUp);
    };

    const calendar = new window.FullCalendar.Calendar(host, {
      initialView: 'dayGridMonth',
      height: 'auto',
      firstDay: 1,
      headerToolbar: {
        left: 'prev,next today',
        center: 'title',
        right: 'dayGridMonth,timeGridWeek,listWeek'
      },
      editable: true,
      eventDurationEditable: false,
      eventsSet: () => {
        refreshSelectionUi(calendar);
      },
      eventDidMount: (arg) => {
        const eventId = String(arg.event.id);
        const list = eventElementMap.get(eventId) || [];
        list.push(arg.el);
        eventElementMap.set(eventId, list);
        arg.el.classList.toggle('calendar-event-selected', selectedEventIds.has(eventId));
      },
      eventWillUnmount: (arg) => {
        const eventId = String(arg.event.id);
        const list = eventElementMap.get(eventId) || [];
        const next = list.filter((el) => el !== arg.el);
        if (next.length) eventElementMap.set(eventId, next);
        else eventElementMap.delete(eventId);
      },
      events: async (_fetchInfo, success, failure) => {
        try {
          const resp = await fetch('/calendar/events?scope=my');
          if (!resp.ok) throw new Error('Failed to load events');
          const data = await resp.json();
          success(Array.isArray(data?.events) ? data.events : []);
        } catch (err) {
          failure(err);
        }
      },
      eventDrop: async (info) => {
        const day = info.event.start ? toDateOnly(info.event.start) : '';
        const draggedId = String(info.event.id);
        const isBatchMove = selectedEventIds.size > 1 && selectedEventIds.has(draggedId);
        try {
          if (!isBatchMove) {
            await patchMove(info.event.id, day);
            return;
          }
          const oldDate = info.oldEvent?.start;
          const newDate = info.event?.start;
          if (!oldDate || !newDate) throw new Error('missing dates');
          const dayMs = 24 * 60 * 60 * 1000;
          const deltaDays = Math.round((newDate.getTime() - oldDate.getTime()) / dayMs);
          const selectedIds = Array.from(selectedEventIds.values()).sort((a, b) => {
            const aEvent = calendar.getEventById(a);
            const bEvent = calendar.getEventById(b);
            const aTime = aEvent?.start?.getTime() ?? 0;
            const bTime = bEvent?.start?.getTime() ?? 0;
            if (aTime !== bTime) return aTime - bTime;
            return String(a).localeCompare(String(b));
          });
          for (const eventId of selectedIds) {
            if (eventId === draggedId) {
              await patchMove(eventId, day);
              continue;
            }
            const event = calendar.getEventById(eventId);
            if (!event?.start) continue;
            const shifted = addDays(event.start, deltaDays);
            const shiftedDay = shifted ? toDateOnly(shifted) : '';
            if (!shiftedDay) continue;
            await patchMove(eventId, shiftedDay);
          }
          await calendar.refetchEvents();
          refreshSelectionUi(calendar);
          return;
        } catch (_err) {
          info.revert();
          await calendar.refetchEvents();
          window.alert('Failed to move date.');
        }
      },
      eventClick: (info) => {
        info.jsEvent.preventDefault();
        const toggleMode = Boolean(info.jsEvent?.shiftKey || info.jsEvent?.metaKey || info.jsEvent?.ctrlKey);
        if (toggleMode) {
          const eventId = String(info.event.id);
          if (selectedEventIds.has(eventId)) selectedEventIds.delete(eventId);
          else selectedEventIds.add(eventId);
          refreshSelectionUi(calendar);
          return;
        }
        openEventDetails(info.event);
      }
    });

    clearSelectionBtn?.addEventListener('click', () => clearSelection(calendar));
    batchMoveBtn?.addEventListener('click', async () => {
      const targetDate = String(batchDateInput?.value || '');
      const selectedIds = Array.from(selectedEventIds.values());
      if (!selectedIds.length) {
        window.alert('Select events first.');
        return;
      }
      if (!targetDate) {
        window.alert('Pick a target date.');
        return;
      }
      const anchor = calendar.getEventById(selectedIds[0]);
      if (!anchor?.start) return;
      const anchorDate = anchor.start;
      const targetBase = new Date(`${targetDate}T00:00:00`);
      const dayMs = 24 * 60 * 60 * 1000;
      const deltaDays = Math.round((targetBase.getTime() - anchorDate.getTime()) / dayMs);
      try {
        for (const eventId of selectedIds) {
          const event = calendar.getEventById(eventId);
          if (!event?.start) continue;
          const next = addDays(event.start, deltaDays);
          const nextDay = next ? toDateOnly(next) : '';
          if (!nextDay) continue;
          await patchMove(eventId, nextDay);
        }
        selectedEventIds.clear();
        await calendar.refetchEvents();
        refreshSelectionUi(calendar);
      } catch (_err) {
        await calendar.refetchEvents();
        window.alert('Failed to move selected events.');
      }
    });

    eventDialog?.querySelectorAll('[data-close]').forEach((btn) => {
      btn.addEventListener('click', () => eventDialog.close());
    });
    host.addEventListener('pointerdown', (event) => {
      startLasso(calendar, event);
    });

    document.addEventListener('mousedown', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;
      if (host.contains(target)) {
        if (!target.closest('.fc-event') && selectedEventIds.size > 0) {
          clearSelection(calendar);
        }
        return;
      }
      if (target.closest('.calendar-tools')) return;
      if (eventDialog && eventDialog.contains(target)) return;
      if (selectedEventIds.size === 0) return;
      clearSelection(calendar);
    });

    updateSelectionCount();
    calendar.render();
  };

  const profileDialog = document.getElementById('profileDialog');
  const openProfileDialog = document.getElementById('openProfileDialog');
  if (openProfileDialog && profileDialog) {
    openProfileDialog.addEventListener('click', () => profileDialog.showModal());
  }
  profileDialog?.querySelectorAll('[data-close]').forEach((btn) => {
    btn.addEventListener('click', () => profileDialog.close());
  });

  const nameInput = document.getElementById('name');
  const nameOutput = document.getElementById('profileName');
  const metaOutput = document.getElementById('profileMeta');
  const emailValue = "<%= (currentUser?.email ?? '').replace(/\"/g, '&quot;') %>";
  const roleValue = "<%= (currentUser?.role ?? 'user').replace(/\"/g, '&quot;') %>";
  const syncProfile = () => {
    if (!nameInput || !nameOutput || !metaOutput) return;
    const nextName = nameInput.value.trim();
    nameOutput.textContent = nextName || emailValue || 'Profile';
    metaOutput.textContent = `${roleValue} · ${emailValue || '-'}`;
  };
  nameInput?.addEventListener('input', syncProfile);
  syncProfile();

  if ("<%= error ? '1' : '' %>" || "<%= notice ? '1' : '' %>") {
    profileDialog?.showModal();
  }

  renderUserCalendar();
</script>
