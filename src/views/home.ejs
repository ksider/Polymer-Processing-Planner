<%- include('partials/head', { title: 'IM Planner | Processes' }) %>
<%- include('partials/nav') %>
<div class="container">
  <div class="card">
    <h1 class="card-title">Processes</h1>
    <p class="small-note">Choose a process card to enter the workspace. Injection is active now.</p>
  </div>

  <div class="card">
    <h2 class="card-title">Available Processes</h2>
    <% if (!processCards || processCards.length === 0) { %>
      <div class="small-note">No visible processes yet.</div>
    <% } %>
    <div class="card-grid">
      <% (processCards || []).forEach((process) => { %>
        <% const processDisplayName = String(process.name || '').replace(/\bDefault\b/gi, '').replace(/\s{2,}/g, ' ').trim(); %>
        <div class="card card-link process-card" style="display:block; cursor:pointer;" data-href="<%= process.route_code ? `/${process.route_code}` : `/?process_id=${process.id}` %>">
          <div class="card-header">
            <div>
              <h3 class="card-title"><%- formatInline(processDisplayName || process.name) %></h3>
              <div class="small-note">Owner: <%- formatInline(process.owner_label || 'Unassigned') %></div>
            </div>
          </div>
          <div class="small-note">Filter experiments on this page</div>
          <div class="small-note">Experiments: <%= Number(process.experiment_count || 0) %></div>
        </div>
      <% }) %>
    </div>
  </div>

  <div class="card">
    <div class="card-header">
      <h2 class="card-title">Recent Experiments</h2>
      <% if (selectedProcess) { %>
        <div class="section-actions">
          <span class="small-note">Process: <%- formatInline(selectedProcess.name) %></span>
          <a class="pure-button" href="/">Show all</a>
        </div>
      <% } %>
    </div>
    <table class="pure-table table-compact">
      <thead>
        <tr>
          <th>ID</th>
          <th>Name</th>
          <th>Process</th>
          <th>Owner</th>
          <th>Status</th>
          <th>Created</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (experiments.length === 0) { %>
          <tr>
            <td colspan="7">No experiments yet.</td>
          </tr>
        <% } %>
        <% experiments.forEach((exp) => { %>
          <tr>
            <td><%= exp.id %></td>
            <td><a href="<%= experimentPath(exp) %>"><%- formatInline(exp.name) %></a></td>
            <td>
              <div><%- formatInline(exp.process_label) %></div>
              <div class="small-note"><%- formatInline(exp.process_type_label) %></div>
            </td>
            <td>
              <% if (exp.owner_user_id) { %>
                <a href="/users/<%= exp.owner_user_id %>"><%= exp.owner_label %></a>
              <% } else { %>
                <%= exp.owner_label %>
              <% } %>
            </td>
            <td><span class="status-pill status-<%= exp.status %>"><%= exp.statusLabel %></span></td>
            <td><%= new Date(exp.created_at).toLocaleDateString() %></td>
            <td>
              <% if (currentUser && (currentUser.role === 'admin' || currentUser.role === 'manager')) { %>
                <form class="pure-form" action="/experiments/<%= exp.id %>/archive" method="post" onsubmit="return confirm('Archive this experiment?');">
                  <button class="pure-button" type="submit">Archive</button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

</div>
<script>
  (() => {
    const processCards = Array.from(document.querySelectorAll('.process-card'));
    processCards.forEach((card) => {
      card.addEventListener('click', (event) => {
        if (event.target && event.target.closest && event.target.closest('.process-settings-open')) return;
        const href = card.getAttribute('data-href');
        if (href) window.location.href = href;
      });
    });
  })();
</script>
<%- include('partials/foot') %>
